# === Base de datos PostgreSQL ===
# Para local: usa localhost. Para AWS RDS: usa el endpoint de RDS.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=multiagente_db
POSTGRES_USER=multiagente_user
POSTGRES_PASSWORD=multiagente_pass

# === JWT Auth ===
SECRET_KEY=cambia-este-secreto-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === WATI WhatsApp API (legado) ===
WATI_API_ENDPOINT=https://live-mt-server.wati.io/TU_TENANT_ID
WATI_BEARER_TOKEN=tu-bearer-token

# === Meta WhatsApp Cloud API ===
META_API_VERSION=v22.0
# Phone Number ID y WABA ID se obtienen en developers.facebook.com/apps -> Tu App -> WhatsApp -> Configuración de API
META_PHONE_NUMBER_ID=tu-phone-number-id
META_WABA_ID=tu-waba-id
META_DISPLAY_PHONE=+573000000000
# Nombre visible verificado en WhatsApp Business (ej: "Tienda Zeniv")
META_VERIFIED_NAME=Tu Negocio
# Correo del usuario al que se le asigna automáticamente la cuenta de Meta.
# Solo el usuario cuyo correo coincida con este valor tendrá WhatsApp conectado.
# El resto de usuarios verán "Sin cuenta de Meta registrada" en su módulo Mi Plan.
META_OWNER_EMAIL=prueba@gmail.com
# Token permanente: developers.facebook.com -> Tu App -> WhatsApp -> Tokens permanentes
META_ACCESS_TOKEN=tu-token-permanente
# Opcionales (referencia)
META_AD_ACCOUNT_ID=
META_PIXEL_ID=
# App secret: Configuración -> Básica -> Clave secreta
META_APP_SECRET=tu-app-secret
# Verify token: lo defines tú y lo pegas en el panel de Meta al configurar el webhook
META_WEBHOOK_VERIFY_TOKEN=cambia-este-token

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# === AWS ===
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
