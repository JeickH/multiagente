# === Base de datos PostgreSQL ===
# Para local: usa localhost. Para AWS RDS: usa el endpoint de RDS.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=multiagente_db
POSTGRES_USER=multiagente_user
POSTGRES_PASSWORD=multiagente_pass

# === JWT Auth ===
SECRET_KEY=cambia-este-secreto-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== Cifrado de secretos multi-tenant =====
# Clave maestra Fernet para cifrar credenciales de cada cliente (tokens de Meta,
# etc.) que se guardan en la base de datos.
#
# Generar con:
#   python backend/scripts/gen_encryption_key.py
#
# IMPORTANTE:
# - Usa claves DISTINTAS en dev, staging y producción.
# - Guarda la clave en un password manager.
# - Perder la clave = perder el acceso permanente a los datos cifrados.
# - Para rotación, setea APP_ENCRYPTION_KEY_OLD con la clave anterior durante
#   el período de transición.
APP_ENCRYPTION_KEY=
# APP_ENCRYPTION_KEY_OLD=  # (opcional, solo durante rotación)

# === WATI WhatsApp API (legado) ===
WATI_API_ENDPOINT=https://live-mt-server.wati.io/TU_TENANT_ID
WATI_BEARER_TOKEN=tu-bearer-token

# === Meta WhatsApp Cloud API ===
# Solo variables GLOBALES (no per-tenant). Las credenciales por cliente
# (phone_number_id, waba_id, access_token, etc.) se guardan cifradas en la
# base de datos — ver tabla meta_accounts y módulo backend/app/services/crypto.py
META_API_VERSION=v22.0
# App secret: Configuración -> Básica -> Clave secreta. Se usa para verificar
# la firma HMAC-SHA256 de los webhooks entrantes de Meta.
META_APP_SECRET=tu-app-secret
# Verify token: lo defines tú y lo pegas en el panel de Meta al configurar el webhook
META_WEBHOOK_VERIFY_TOKEN=cambia-este-token

# === Sprint 13: envío de campañas ===
# Modo sandbox: si =1 NO se llama a Meta, se simula `wamid.local-<uuid>`.
# Default en docker-compose local = 1. En producción debe ser 0.
META_SANDBOX=1
# Rate-limit del sender por meta_account_id (token-bucket, msg/s).
META_RATE_LIMIT_RPS=10
# Máximo de recipients procesados por tick por campaña.
CAMPAIGN_SENDER_BATCH=200
# Shared secret para endpoints internos (`X-Internal-Key`). Si vacío en dev,
# el endpoint queda abierto (fail-open dev). En producción es obligatorio.
INTERNAL_API_KEY=

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# === AWS ===
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
