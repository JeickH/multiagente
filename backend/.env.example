# Para local: localhost | Para AWS RDS: tu-endpoint.rds.amazonaws.com
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=multiagente_db
POSTGRES_USER=multiagente_user
POSTGRES_PASSWORD=multiagente_pass
SECRET_KEY=cambia-este-secreto-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
WATI_API_ENDPOINT=
WATI_BEARER_TOKEN=

# ===== Twilio (Sprint 18) =====
# Mientras no exista la cuenta, dejar TWILIO_SANDBOX=1 (envío simulado).
# Cuando la cuenta esté lista: pegar las claves y poner TWILIO_SANDBOX=0.
TWILIO_SANDBOX=1
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Uno de los dos (MessagingServiceSid tiene prioridad):
TWILIO_WHATSAPP_FROM=
TWILIO_MESSAGING_SERVICE_SID=
# URL pública base del webhook (para verificar la firma detrás de API Gateway):
TWILIO_WEBHOOK_BASE_URL=

# ===== LLM / AWS Bedrock (Sprint 19) =====
# El motor de bots LLM usa las credenciales AWS del entorno (IAM task role en
# ECS, ~/.aws en local). No hay API key. Defaults razonables:
BEDROCK_REGION=sa-east-1
LLM_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
LLM_MAX_TOKENS=1024
